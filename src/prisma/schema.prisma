generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "mysql"
}

model Booking {
  id Int @id @default(autoincrement())

  userId        Int
  roomId        Int
  bookingAmount Int
  status        bookingStatus
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum bookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
